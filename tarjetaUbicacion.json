{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.4",
  "body": [
    {
      "type": "TextBlock",
      "text": "📍 Reportar Ubicación del Agente",
      "weight": "Bolder",
      "size": "Medium",
      "color": "Accent"
    },
    {
      "type": "Input.Text",
      "id": "latitud",
      "label": "Latitud",
      "placeholder": "Ej: 4.6097",
      "isRequired": true,
      "errorMessage": "La latitud es obligatoria"
    },
    {
      "type": "Input.Text",
      "id": "longitud",
      "label": "Longitud",
      "placeholder": "Ej: -74.0817",
      "isRequired": true,
      "errorMessage": "La longitud es obligatoria"
    },
    {
      "type": "Input.Text",
      "id": "descripcion",
      "label": "Descripción del reporte",
      "placeholder": "Escribe una breve descripción...",
      "isMultiline": true
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Enviar Reporte",
      "data": {
        "id": "guardar_reporte"
      }
    }
  ]
}